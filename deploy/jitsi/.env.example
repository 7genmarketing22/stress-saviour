# Target VPS/domain. Create an A record before running configure.sh.
JITSI_DOMAIN=meet.example.com
LETSENCRYPT_EMAIL=admin@example.com

# Must exactly match the Next.js JITSI_APP_ID/JITSI_APP_SECRET values.
JWT_APP_ID=stress-saviour
JWT_APP_SECRET=replace-with-at-least-32-random-bytes

# Optional. The script selects the newest upstream stable-* tag by default.
JITSI_DOCKER_TAG=
JITSI_UPSTREAM_DIR=/opt/docker-jitsi-meet
TZ=Asia/Karachi
