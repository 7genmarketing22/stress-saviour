# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Or use the legacy anon JWT key instead:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Legacy service role JWT or new secret key (sb_secret_...) — optional for most features.
# Staff provisioning uses a secure database function and does not require this key.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# SUPABASE_SECRET_KEY=your-supabase-secret-key

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Payment Gateways
# JazzCash
JAZZCASH_MERCHANT_ID=your-jazzcash-merchant-id
JAZZCASH_PASSWORD=your-jazzcash-password
JAZZCASH_INTEGRITY_SALT=your-jazzcash-integrity-salt

# EasyPaisa
EASYPAISA_STORE_ID=your-easypaisa-store-id
EASYPAISA_HASH_KEY=your-easypaisa-hash-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Notifications
# Email (Resend)
RESEND_API_KEY=your-resend-api-key

# Web Push (generate a matching pair once with: npm run push:generate-keys)
# Paste ONLY the key strings (no quotes). Public + private must be from the SAME generate run.
# Put real keys in .env.local (local) and Vercel Env Vars (production) — NEVER in this example file.
# After changing keys on Vercel, redeploy.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@stresssaviors.pk

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Video Conferencing — free self-hosted Jitsi + Prosody JWT.
# See deploy/jitsi/README.md. Production joins fail closed when this is absent,
# avoiding meet.jit.si's login prompt.
JITSI_DOMAIN=meet.your-domain.pk
JITSI_APP_ID=stress-saviour
JITSI_APP_SECRET=use-the-same-random-secret-as-the-jitsi-vps
# Use a different secret for deterministic, non-guessable appointment rooms.
JITSI_ROOM_SECRET=use-a-different-random-room-secret

# Cron (appointment expiry sweep — optional; dashboards also trigger sync)
CRON_SECRET=your-random-cron-secret

# Public site URL (emails + push deep links).
# Local: http://localhost:3000
# Production: use your primary Vercel URL (both deployments can share the same keys).
NEXT_PUBLIC_APP_URL=https://stress-saviour.vercel.app
PLATFORM_FEE_PERCENT=10

# Development
NODE_ENV=development
