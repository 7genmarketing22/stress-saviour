# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# Or use the legacy anon JWT key instead:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Legacy service role JWT or new secret key (sb_secret_...) — optional for most features.
# Staff provisioning uses a secure database function and does not require this key.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# SUPABASE_SECRET_KEY=your-supabase-secret-key

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret-key
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Payment Gateways
# JazzCash
JAZZCASH_MERCHANT_ID=your-jazzcash-merchant-id
JAZZCASH_PASSWORD=your-jazzcash-password
JAZZCASH_INTEGRITY_SALT=your-jazzcash-integrity-salt

# EasyPaisa
EASYPAISA_STORE_ID=your-easypaisa-store-id
EASYPAISA_HASH_KEY=your-easypaisa-hash-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Notifications
# Email (Resend)
RESEND_API_KEY=your-resend-api-key

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Video Conferencing — Jitsi
# Domain of your Jitsi deployment. Defaults to meet.jit.si (anonymous mode —
# note meet.jit.si forces the first participant to authenticate as moderator).
JITSI_DOMAIN=meet.jit.si
# Secret used to derive non-guessable room names (falls back to JITSI_APP_SECRET / NEXTAUTH_SECRET).
JITSI_ROOM_SECRET=your-random-room-secret
#
# Option A: JaaS (8x8.vc) — RS256 JWT. Doctor joins as moderator, patient as participant, no login prompts.
# JITSI_DOMAIN=8x8.vc
# JITSI_APP_ID=vpaas-magic-cookie-xxxxxxxx
# JITSI_KID=vpaas-magic-cookie-xxxxxxxx/xxxxxx
# JITSI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
#
# Option B: Self-hosted Jitsi with prosody token auth (enableUserRolesBasedOnToken) — HS256 JWT.
# JITSI_DOMAIN=meet.your-domain.pk
# JITSI_APP_ID=stress-saviours
# JITSI_APP_SECRET=your-jitsi-app-secret

# Cron (appointment expiry sweep — optional; dashboards also trigger sync)
CRON_SECRET=your-random-cron-secret

NEXT_PUBLIC_APP_URL=http://localhost:3000
PLATFORM_FEE_PERCENT=10

# Development
NODE_ENV=development
